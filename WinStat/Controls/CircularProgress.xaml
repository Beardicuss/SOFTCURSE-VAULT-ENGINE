<UserControl x:Class="BorderlandsStorageCleaner.WinStat.Controls.CircularProgress"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" Height="220">
    <UserControl.Resources>
        <Storyboard x:Key="RotateRing">
            <DoubleAnimation Storyboard.TargetName="OuterRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:3" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="InnerRing"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="360" To="0" Duration="0:0:5" RepeatBehavior="Forever"/>
        </Storyboard>
    </UserControl.Resources>
    
    <Grid>
        <!-- Outer Rotating Ring (Futuristic) -->
        <Path x:Name="OuterRing"
              Stroke="#FF6600"
              StrokeThickness="2"
              StrokeDashArray="2 4"
              Width="210" Height="210"
              RenderTransformOrigin="0.5,0.5"
              Data="M 105,0 A 105,105 0 1 1 104.9,0 Z">
            <Path.RenderTransform>
                <RotateTransform Angle="0"/>
            </Path.RenderTransform>
            <Path.Effect>
                <DropShadowEffect Color="#FF6600" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
            </Path.Effect>
        </Path>

        <!-- Inner Rotating Ring -->
        <Path x:Name="InnerRing"
              Stroke="#FF8800"
              StrokeThickness="1"
              StrokeDashArray="10 10"
              Width="180" Height="180"
              RenderTransformOrigin="0.5,0.5"
              Data="M 90,0 A 90,90 0 1 1 89.9,0 Z"
              Opacity="0.5">
            <Path.RenderTransform>
                <RotateTransform Angle="0"/>
            </Path.RenderTransform>
        </Path>

        <!-- Background Track -->
        <Ellipse Stroke="#1A1A1A" 
                 StrokeThickness="12"
                 Width="150" Height="150"
                 Fill="Transparent"/>

        <!-- Progress Ring -->
        <Path x:Name="ProgressPath"
              Stroke="#FF6600"
              StrokeThickness="12"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Fill="Transparent"
              Width="150" Height="150">
            <Path.Effect>
                <DropShadowEffect Color="#FF6600"
                                  BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.8"/>
            </Path.Effect>
        </Path>

        <!-- Percentage Text -->
        <TextBlock x:Name="PercentageText"
                   Text="0%"
                   Foreground="#FF6600"
                   FontSize="36"
                   FontWeight="Bold"
                   FontFamily="Consolas"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center">
            <TextBlock.Effect>
                <DropShadowEffect Color="#FF6600"
                                  BlurRadius="10"
                                  ShadowDepth="0"
                                  Opacity="0.5"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</UserControl>
