                        <!-- Rows -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Basic Cleanup" FontFamily="Consolas" FontSize="11" Foreground="#ccc" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="✅" HorizontalAlignment="Center" FontSize="12" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="✅" HorizontalAlignment="Center" FontSize="12" Margin="0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Quick Scan" FontFamily="Consolas" FontSize="11" Foreground="#ccc" Margin="0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="✅" HorizontalAlignment="Center" FontSize="12" Margin="0,4"/>
