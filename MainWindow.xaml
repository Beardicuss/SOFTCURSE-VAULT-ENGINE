<Window x:Class="BorderlandsStorageCleaner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BorderlandsStorageCleaner"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SOFTCURSE VAULT ENGINE v3.0"
        Height="750" Width="1000"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        MinWidth="800"
        MinHeight="600">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.95">
            <GradientStop Color="#020202" Offset="0.0"/>
            <GradientStop Color="#050510" Offset="0.3"/>
            <GradientStop Color="#001010" Offset="0.5"/>
            <GradientStop Color="#050510" Offset="0.7"/>
            <GradientStop Color="#020202" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="OrangeGlow" Color="#00FFFF"/> <!-- Cyan Accent -->
        <SolidColorBrush x:Key="RedGlow" Color="#FF00FF"/>    <!-- Magenta Glitch -->
        <SolidColorBrush x:Key="DarkBg" Color="#020202"/>     <!-- Deep Black -->
        <SolidColorBrush x:Key="PanelBg" Color="#050505"/>    <!-- Lighter Black -->
        <SolidColorBrush x:Key="BorderColor" Color="#00FFFF"/>

        <!-- Semi-transparent cyan for selection -->
        <SolidColorBrush x:Key="SelectionBrush" Color="#00FFFF" Opacity="0.3"/>
        
        <!-- Visibility Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>

        <!-- Tech Button Style with Animations -->
        <Style x:Key="TechButton" TargetType="Button">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#00FFFF"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect x:Name="shadow" Color="#00FFFF" BlurRadius="10" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="#003333" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="shadow" 
                                                          Storyboard.TargetProperty="Color"
                                                          To="#0088FF" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow" 
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="20" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="#050505" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="shadow" 
                                                          Storyboard.TargetProperty="Color"
                                                          To="#00FFFF" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow" 
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="10" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0088FF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#440044"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF00FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#0A0A0A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#444444"/>
                                <Setter Property="Foreground" Value="#444444"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tech CheckBox Style -->
        <Style x:Key="TechCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="16" Height="16" Margin="0,0,8,0"
                                    Background="#020202" BorderBrush="#00FFFF" BorderThickness="2">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FFFF" BlurRadius="5" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock x:Name="checkMark" Text="✓" Foreground="#00FFFF" 
                                           FontWeight="Bold" HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" Visibility="Collapsed"/>
                            </Border>

                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkMark" Property="Foreground" Value="#0088FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tech TextBox Style -->
        <Style x:Key="TechTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#020202"/>
            <Setter Property="Foreground" Value="#00FFFF"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="CaretBrush" Value="#00FFFF"/>
            <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrush}"/>
        </Style>

        <!-- ToolTip Style -->
        <Style x:Key="TechToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#00FFFF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Tech Tab Style -->
        <Style x:Key="TechTabItem" TargetType="TabItem">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#00FFFF" BorderThickness="0,0,0,0"
                                Padding="16,8" Margin="0,0,2,0">
                            <ContentPresenter x:Name="cp"
                                ContentSource="Header"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                TextElement.FontWeight="Bold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"   Value="#0a1a1a"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter TargetName="cp" Property="TextElement.Foreground" Value="#00FFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"   Value="#081212"/>
                                <Setter TargetName="cp" Property="TextElement.Foreground" Value="#aaaaaa"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox Style -->
        <Style x:Key="TechComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#00FFFF"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press" Focusable="false">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#050505"
                                                BorderBrush="#00FFFF" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="18"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="#0a1a1a">
                                                    <Path x:Name="Arrow" Fill="#00FFFF" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="M 0 0 L 4 4 L 8 0 Z"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="6,2,20,2" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#0a0a0a"
                                            BorderBrush="#00FFFF" BorderThickness="1"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#0a0a0a"/>
                    <Setter Property="Foreground" Value="#00FFFF"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="Padding" Value="6,3"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#003333"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <!-- Main Container with Resize Borders -->
   <Grid>

        <!-- BACKGROUND LOGO -->
        <Image Source="Resources/softcurse_logo.png"
               Stretch="Uniform"
               Opacity="0.12"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False">
            <Image.OpacityMask>
                <ImageBrush ImageSource="Resources/softcurse_logo.png"/>
            </Image.OpacityMask>

            <Image.Effect>
                <DropShadowEffect 
                    Color="#00FFFF"
                    BlurRadius="40"
                    ShadowDepth="0"
                    Opacity="0.8"/>
            </Image.Effect>
        </Image>


        <!-- Resize Borders (only visible in windowed mode) -->
        <Border x:Name="resizeBorder" Background="Transparent" 
                BorderBrush="#00FFFF" BorderThickness="3" 
                CornerRadius="0" Visibility="Visible">

            <!-- Inner content area -->
            <Border Background="#CC020202" Margin="3">
                <Border.Effect>
                    <DropShadowEffect Color="#00FFFF" BlurRadius="40" ShadowDepth="0" Opacity="0.9"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE BAR -->
                    <Border Grid.Row="0" Background="#050505" BorderBrush="#00FFFF" BorderThickness="0,0,0,2"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0">
                                <TextBlock Text=" SOFTCURSE VAULT ENGINE v3.0 "
                                           FontFamily="Consolas"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#00FFFF">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00FFFF" BlurRadius="10" ShadowDepth="0"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock x:Name="txtAdminStatus"
                                           Text="[ADMIN PRIVILEGES: CHECKING...]"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="#FF00FF"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10">
                                <Button Content="–" Width="40" Height="30" Style="{StaticResource TechButton}" 
                                        Click="MinimizeWindow" ToolTip="Minimize"/>
                                <Button Content="✕" Width="40" Height="30" Style="{StaticResource TechButton}" 
                                        Click="CloseWindow" ToolTip="Close"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Action Buttons (Removed: Duplicates of Left Panel buttons and caused layout issues) -->

                    <!-- MAIN CONTENT — Tabbed Layout -->
                    <Grid Grid.Row="1">
                        <TabControl Background="#020202" BorderBrush="#00FFFF" BorderThickness="0,1,0,0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem" BasedOn="{StaticResource TechTabItem}"/>
                            </TabControl.Resources>

                            <!-- ══ TAB 1: VAULT CLEANER (original) ══ -->
                            <TabItem Header="  🧹 VAULT CLEANER  " Style="{StaticResource TechTabItem}">
                                <Grid Margin="15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- LEFT PANEL -->
                        <Border Grid.Column="0" Background="#050505" BorderBrush="#00FFFF" BorderThickness="2" Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#00FFFF" BlurRadius="25" Opacity="0.5"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="280"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="15,15,15,5">
                                    <TextBlock Text=" SYSTEM STATUS" Foreground="#00FFFF" FontWeight="Bold" 
                                               FontFamily="Consolas" FontSize="14"/>
                                    <TextBlock x:Name="txtDiskSpace" Text="{Binding DiskSpace}" Foreground="#00FF00" 
                                               FontFamily="Consolas" Margin="0,5"/>
                                    <TextBlock x:Name="txtStatus" Text="{Binding Status}" Foreground="#0088FF" 
                                               FontFamily="Consolas"/>
                                    <TextBlock x:Name="txtTimeElapsed" Text="{Binding TimeElapsed}" Foreground="#CCCCCC" 
                                               FontFamily="Consolas" FontSize="11"/>
                                    <TextBlock x:Name="txtSpaceFreed" Text="{Binding SpaceFreed}" Foreground="#CCCCCC" 
                                               FontFamily="Consolas" FontSize="11"/>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="20">
                                    <!-- STANDBY MODE: WebView2 Cube Loader -->
                                    <wv2:WebView2 x:Name="loaderStandby" 
                                                  DefaultBackgroundColor="Transparent"
                                                  Visibility="{Binding IsCleaning, Converter={StaticResource InvertBoolToVis}}"/>
                                    
                                    <!-- ACTIVE MODE: WebView2 Boxes Loader -->
                                    <wv2:WebView2 x:Name="loaderActive" 
                                                  DefaultBackgroundColor="Transparent"
                                                  Visibility="{Binding IsCleaning, Converter={StaticResource BoolToVisibility}}"/>
                                    
                                    <!-- Progress Text Overlay -->
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Foreground="#00FFFF" FontWeight="Bold" FontFamily="Consolas" 
                                                   FontSize="12" TextAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="CLEANUP: {0}%">
                                                    <Binding Path="Progress"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Status}" Foreground="#CCCCCC" FontFamily="Consolas"
                                                   FontSize="10" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="200" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>


                                            

                                            

                                            

                                    



                                <ProgressBar x:Name="progressBar" Grid.Row="2" Height="20" Margin="20,10"
                                             Value="{Binding Progress, Mode=OneWay}" Maximum="100"
                                             Foreground="#00FFFF" Background="#020202" 
                                             BorderBrush="#00FFFF" BorderThickness="2"
                                             ToolTip="Overall cleanup progress"/>

                                <StackPanel Grid.Row="3" Margin="20">
                                    <Button x:Name="btnStart" Content="INITIATE CLEANUP PROTOCOL" 
                                        Style="{StaticResource TechButton}" Command="{Binding StartCleaningCommand}" Margin="0,5"
                                        ToolTip="Start comprehensive storage cleanup"/>
                                    <Button x:Name="btnQuickScan" Content="QUICK SCAN" 
                                        Style="{StaticResource TechButton}" Command="{Binding QuickScanCommand}" Margin="0,5"
                                        ToolTip="Quick scan for temporary files"/>
                                    <Button x:Name="btnAbort" Content="ABORT MISSION" 
                                        Style="{StaticResource TechButton}" Command="{Binding AbortCleaningCommand}" Margin="0,5"
                                        ToolTip="Cancel current operation"/>

                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- RIGHT PANEL -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="220"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#050505" BorderBrush="#00FFFF" BorderThickness="2" Margin="10,0,0,10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FFFF" BlurRadius="15" Opacity="0.4"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text=" SYSTEM LOG" Foreground="#00FFFF" FontWeight="Bold" 
                                               FontFamily="Consolas" Margin="15,10"/>

                                    <!-- Background Logo -->
                                    <Image Grid.Row="1" Source="Resources/logo-Photoroom.png" 
                                           Stretch="Uniform" 
                                           Opacity="0.15" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>

                                    <ScrollViewer Grid.Row="1" Margin="10,5,10,10" VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBox x:Name="txtLog" IsReadOnly="True" Background="Transparent" 
                                                 Foreground="#00FF00" FontFamily="Consolas" FontSize="11" 
                                                 TextWrapping="Wrap" BorderThickness="0" VerticalAlignment="Top"
                                                 Text="{Binding LogText, Mode=OneWay}"
                                                 TextChanged="TxtLog_TextChanged"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="#050505" BorderBrush="#00FFFF" BorderThickness="2" Margin="10,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FFFF" BlurRadius="15" Opacity="0.4"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="15">
                                        <TextBlock Text=" CONFIGURATION" Foreground="#00FFFF" FontWeight="Bold" 
                                                   FontFamily="Consolas" FontSize="14" Margin="0,0,0,10"/>

                                        <CheckBox x:Name="chkTempFiles" Content="Delete temporary files" 
                                                  Style="{StaticResource TechCheckBox}" Margin="0,5" 
                                                  IsChecked="{Binding CleanTempFiles}"/>
                                        <CheckBox x:Name="chkCache" Content="Clear application cache" 
                                                  Style="{StaticResource TechCheckBox}" Margin="0,5" 
                                                  IsChecked="{Binding CleanCache}"/>
                                        <CheckBox x:Name="chkLogs" Content="Remove old log files" 
                                                  Style="{StaticResource TechCheckBox}" Margin="0,5" 
                                                  IsChecked="{Binding CleanLogs}"/>
                                        <CheckBox x:Name="chkRecycleBin" Content="Empty recycle bin" 
                                                  Style="{StaticResource TechCheckBox}" Margin="0,5" 
                                                  IsChecked="{Binding CleanRecycleBin}"/>
                                        <CheckBox x:Name="chkPrefetch" Content="Clear prefetch data" 
                                                  Style="{StaticResource TechCheckBox}" Margin="0,5" 
                                                  IsChecked="{Binding CleanPrefetch}"/>

                                        <TextBlock Text="Custom folders to clean:" Foreground="#CCCCCC" 
                                                   FontFamily="Consolas" FontSize="11" Margin="0,15,0,5"/>
                                        <ListBox x:Name="lstCustomFolders" Height="60" 
                                                 Background="#020202" Foreground="#00FFFF" 
                                                 BorderBrush="#00FFFF" BorderThickness="1"
                                                 FontFamily="Consolas" FontSize="11"
                                                 ItemsSource="{Binding CustomFolders}"
                                                 SelectedItem="{Binding SelectedCustomFolder}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Button Content="+ ADD FOLDER" Style="{StaticResource TechButton}" 
                                                    FontSize="10" Padding="8,4" Margin="0,0,5,0"
                                                    Click="BtnAddFolder_Click"/>
                                            <Button Content="- REMOVE" Style="{StaticResource TechButton}" 
                                                    FontSize="10" Padding="8,4"
                                                    Command="{Binding RemoveFolderCommand}"/>
                                        </StackPanel>

                                        <TextBlock Text="Advanced options:" Foreground="#CCCCCC" 
                                                   FontFamily="Consolas" FontSize="11" Margin="0,15,0,5"/>
                                        <CheckBox x:Name="chkDeepScan" Content="Deep scan mode" 
                                                  Style="{StaticResource TechCheckBox}" Margin="0,5" 
                                                  IsChecked="{Binding DeepScanMode}"/>
                                        <CheckBox x:Name="chkBackup" Content="Create backup before deletion" 
                                                  Style="{StaticResource TechCheckBox}" Margin="0,5" 
                                                  IsChecked="{Binding CreateBackup}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                            </TabItem>

<TabItem Header="  💽 DISK ANALYZER  " Style="{StaticResource TechTabItem}">
    <Grid DataContext="{Binding DiskAnalyzer}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Drive bar ─────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#050505" BorderBrush="#00FFFF"
                BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding DriveInfo}" Foreground="#00FFFF"
                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8" Margin="0,6,0,3"
                                 Foreground="#00FFFF" Background="#111" BorderBrush="#00FFFF" BorderThickness="1"/>
                    <TextBlock Text="{Binding Status}" Foreground="#888"
                               FontFamily="Consolas" FontSize="10"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Background="#0a1a1a" BorderBrush="#00FFFF" BorderThickness="1" Margin="3,2" Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅ Safe: " Foreground="#888" FontFamily="Consolas" FontSize="10"/>
                            <TextBlock Text="{Binding SafeTotalStr}" Foreground="#4ade80" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0a1a1a" BorderBrush="#00FFFF" BorderThickness="1" Margin="3,2" Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ Review: " Foreground="#888" FontFamily="Consolas" FontSize="10"/>
                            <TextBlock Text="{Binding ReviewTotalStr}" Foreground="#fbbf24" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0a1a1a" BorderBrush="#00FFFF" BorderThickness="1" Margin="3,2" Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦 Large: " Foreground="#888" FontFamily="Consolas" FontSize="10"/>
                            <TextBlock Text="{Binding LargeCountStr}" Foreground="#00FFFF" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0a1a1a" BorderBrush="#00FFFF" BorderThickness="1" Margin="3,2" Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥 Apps: " Foreground="#888" FontFamily="Consolas" FontSize="10"/>
                            <TextBlock Text="{Binding ProgCountStr}" Foreground="#00FFFF" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ── Inner tabs ────────────────────────────────────── -->
        <TabControl Grid.Row="1" Background="#020202" BorderBrush="#222" BorderThickness="0,1,0,0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#050505"/>
                    <Setter Property="Foreground" Value="#666666"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize"   Value="11"/>
                    <Setter Property="Padding"    Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="tabBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#222" BorderThickness="1,1,1,0"
                                        Padding="12,5" Margin="0,0,2,0">
                                    <ContentPresenter x:Name="tabContent"
                                        ContentSource="Header"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        TextElement.FontFamily="{TemplateBinding FontFamily}"
                                        TextElement.FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#0a1a1a"/>
                                        <Setter TargetName="tabBorder" Property="BorderBrush" Value="#00FFFF"/>
                                        <Setter TargetName="tabContent" Property="TextElement.Foreground" Value="#00FFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#081212"/>
                                        <Setter TargetName="tabContent" Property="TextElement.Foreground" Value="#aaaaaa"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="DataGrid">
                    <Setter Property="Background"           Value="#050505"/>
                    <Setter Property="Foreground"           Value="#cccccc"/>
                    <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
                    <Setter Property="HorizontalGridLinesBrush" Value="#111"/>
                    <Setter Property="BorderThickness"      Value="0"/>
                    <Setter Property="RowBackground"        Value="#050505"/>
                    <Setter Property="AlternatingRowBackground" Value="#080808"/>
                    <Setter Property="FontFamily"           Value="Consolas"/>
                    <Setter Property="FontSize"             Value="11"/>
                    <Setter Property="SelectionMode"        Value="Single"/>
                    <Setter Property="AutoGenerateColumns"  Value="False"/>
                    <Setter Property="IsReadOnly"           Value="False"/>
                    <Setter Property="CanUserSortColumns"   Value="True"/>
                    <Setter Property="HeadersVisibility"    Value="Column"/>
                </Style>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"        Value="#0a0a0a"/>
                    <Setter Property="Foreground"        Value="#00FFFF"/>
                    <Setter Property="FontFamily"        Value="Consolas"/>
                    <Setter Property="FontSize"          Value="10"/>
                    <Setter Property="Padding"           Value="8,4"/>
                    <Setter Property="BorderBrush"       Value="#222"/>
                    <Setter Property="BorderThickness"   Value="0,0,1,1"/>
                </Style>
                <Style TargetType="DataGridCheckBoxColumn"/>

                <!-- Kill white selection highlight on rows -->
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Background"            Value="#050505"/>
                    <Setter Property="Foreground"            Value="#cccccc"/>
                    <Setter Property="BorderBrush"           Value="#111"/>
                    <Setter Property="BorderThickness"       Value="0,0,0,1"/>
                </Style>
                <!-- Kill white cell selection box -->
                <Style TargetType="DataGridCell">
                    <Setter Property="Background"   Value="Transparent"/>
                    <Setter Property="BorderBrush"  Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background"  Value="#0d2020"/>
                            <Setter Property="BorderBrush" Value="#00FFFF"/>
                            <Setter Property="Foreground"  Value="#00FFFF"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="#00FFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ═══ TAB 1: Overview ════════════════════════════════════════ -->
            <TabItem Header="📊 Overview">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text=" Top-Level C:\\ Folder Sizes (read-only — use tabs below to delete)"
                               Foreground="#00FFFF" FontFamily="Consolas" FontWeight="Bold" FontSize="11" Margin="10,8"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding TopFolders}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#050505"/>
                                <Setter Property="Foreground" Value="#cccccc"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="  Folder"      Binding="{Binding Name}"    Width="220" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size"          Binding="{Binding SizeStr}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="% of Drive"    Binding="{Binding PctStr}"  Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Note / Action" Binding="{Binding Note}"    Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 2: Junk Scan ═══════════════════════════════════════ -->
            <TabItem Header="🗑 Junk Scan">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,6" Background="#050505">
                        <TextBlock Text="Filter: " Foreground="#888" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding JunkCategories}"
                                  SelectedItem="{Binding JunkFilter, Mode=TwoWay}"
                                  Style="{StaticResource TechComboBox}"
                                  Width="120" Margin="4,0,12,0"/>
                        <Button Content="☑ Select All"  Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding SelectAllJunkCommand}"/>
                        <Button Content="✅ Safe Only"  Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding SelectSafeJunkCommand}"/>
                        <Button Content="☐ Deselect"   Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding DeselectAllJunkCommand}"/>
                        <Button Content="📋  SEND TO VAULT CLEANER" Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="16,0,2,0"
                                Command="{Binding SendJunkToVaultCommand}"/>
                    </StackPanel>

                    <!-- Grid with checkboxes -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding JunkFiltered}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#050505"/>
                                <Setter Property="Foreground" Value="#cccccc"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Safe}" Value="True">
                                        <Setter Property="Foreground" Value="#4ade80"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Safe}" Value="False">
                                        <Setter Property="Foreground" Value="#fbbf24"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                        <Setter Property="Background" Value="#0a1a0a"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                            <DataGridTextColumn Header="  Location"    Binding="{Binding Label}"    Width="240" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size"          Binding="{Binding SizeStr}"  Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Safe?"         Binding="{Binding SafeStr}"  Width="80"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Category"      Binding="{Binding Category}" Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Note / Action" Binding="{Binding Note}"     Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Delete bar -->
                    <Border Grid.Row="2" Background="#050508" BorderBrush="#00FFFF" BorderThickness="0,1,0,0" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🗑  DELETE SELECTED" Style="{StaticResource TechButton}"
                                    FontSize="12" Padding="14,6" Background="#1a0000" BorderBrush="#ff5f6d"
                                    Foreground="#ff5f6d" Command="{Binding DeleteJunkCommand}"/>
                            <TextBlock Grid.Column="1" Text="{Binding JunkSelectedStr}"
                                       Foreground="#fbbf24" FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" Margin="16,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 3: Large Files ═════════════════════════════════════ -->
            <TabItem Header="📦 Large Files">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,6" Background="#050505">
                        <TextBlock Text="Drive: " Foreground="#888" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableDrives}"
                                  SelectedItem="{Binding SelectedDrive, Mode=TwoWay}"
                                  Style="{StaticResource TechComboBox}"
                                  Width="70" Margin="4,0,12,0"/>
                        <TextBlock Text="Min size: " Foreground="#888" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding MinFileSizeLabel, Mode=TwoWay}"
                                  Style="{StaticResource TechComboBox}"
                                  Width="100" Margin="4,0,12,0">
                            <ComboBoxItem Content="10 MB"/><ComboBoxItem Content="50 MB"/>
                            <ComboBoxItem Content="100 MB" IsSelected="True"/>
                            <ComboBoxItem Content="500 MB"/><ComboBoxItem Content="1 GB"/>
                        </ComboBox>
                        <Button Content="☑ Select All"  Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding SelectAllLargeCommand}"/>
                        <Button Content="☐ Deselect"    Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding DeselectAllLargeCommand}"/>
                        <Button Content="📁 Open in Explorer" Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="12,0,2,0"
                                Command="{Binding OpenFileLocationCommand}"
                                CommandParameter="{Binding SelectedItem.Path, ElementName=dgLargeFiles}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="dgLargeFiles" ItemsSource="{Binding LargeFiles}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#050505"/>
                                <Setter Property="Foreground" Value="#cccccc"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                        <Setter Property="Background" Value="#0a1a0a"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                            <DataGridTextColumn Header="  File Path" Binding="{Binding Path}"    Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size"        Binding="{Binding SizeStr}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type"        Binding="{Binding Ext}"     Width="65"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Folder"      Binding="{Binding Folder}"  Width="300" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Delete bar -->
                    <Border Grid.Row="2" Background="#050508" BorderBrush="#00FFFF" BorderThickness="0,1,0,0" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🗑  DELETE SELECTED FILES" Style="{StaticResource TechButton}"
                                    FontSize="12" Padding="14,6" Background="#1a0000" BorderBrush="#ff5f6d"
                                    Foreground="#ff5f6d" Command="{Binding DeleteLargeCommand}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="📋  SEND TO VAULT CLEANER" Style="{StaticResource TechButton}"
                                    FontSize="12" Padding="14,6" Background="#001a10" BorderBrush="#00FFFF"
                                    Foreground="#00FFFF" Command="{Binding SendLargeToVaultCommand}"/>
                            <TextBlock Grid.Column="2" Text="{Binding LargeSelectedStr}"
                                       Foreground="#fbbf24" FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" Margin="16,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 4: Duplicates ══════════════════════════════════════ -->
            <TabItem Header="👥 Duplicates">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,6" Background="#050505">
                        <TextBlock Text="Scan folder: " Foreground="#888" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding DupRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TechTextBox}" Width="300" Margin="4,0,4,0"/>
                        <Button Content="📁 Browse" Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="0,0,8,0"
                                Click="BtnBrowseDupFolder_Click"/>
                        <Button Content="▶ FIND DUPES" Style="{StaticResource TechButton}" FontSize="10" Padding="10,3" Margin="2,0,16,0"
                                Command="{Binding DupScanCommand}"/>
                        <Button Content="☑ Select All Dupes" Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding SelectAllDupesCommand}"/>
                        <Button Content="☐ Deselect" Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding DeselectAllDupesCommand}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding DupeRows}" IsReadOnly="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#050505"/>
                                <Setter Property="Foreground" Value="#cccccc"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                        <Setter Property="Foreground" Value="#00FFFF"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDupe}" Value="True">
                                        <Setter Property="Foreground" Value="#fbbf24"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                        <Setter Property="Background" Value="#1a1000"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" Width="36"/>
                            <DataGridTextColumn Header="Group"  Binding="{Binding GroupLabel}" Width="55"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="  File Path" Binding="{Binding FilePath}" Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size"   Binding="{Binding SizeStr}"    Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Hash"   Binding="{Binding Hash}"       Width="115" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Info"   Binding="{Binding WastedInfo}" Width="130" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#050508" BorderBrush="#00FFFF" BorderThickness="0,1,0,0" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🗑  DELETE CHECKED DUPLICATES" Style="{StaticResource TechButton}"
                                    FontSize="12" Padding="14,6" Background="#1a0000" BorderBrush="#ff5f6d"
                                    Foreground="#ff5f6d" Command="{Binding DeleteDupesCommand}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DupeSelectedStr}"
                                       Foreground="#fbbf24" FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" Margin="16,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 5: Programs ════════════════════════════════════════ -->
            <TabItem Header="🖥 Programs">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0a1a0a" BorderBrush="#00FFFF" BorderThickness="0,0,0,1" Padding="12,6">
                        <TextBlock Foreground="#888" FontFamily="Consolas" FontSize="10"
                                   Text="Programs are listed for reference only. To uninstall: Windows Settings → Apps → Apps &amp; features"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Programs}" IsReadOnly="True">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#050505"/>
                                <Setter Property="Foreground" Value="#cccccc"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="  Application" Binding="{Binding Name}"     Width="320"/>
                            <DataGridTextColumn Header="Size"          Binding="{Binding SizeStr}"  Width="100"/>
                            <DataGridTextColumn Header="Path"          Binding="{Binding FullPath}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 6: Suggestions ════════════════════════════════════ -->
            <TabItem Header="💡 Suggestions">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,6" Background="#050505">
                        <Button Content="☑ Select All Safe"  Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding SelectAllSuggestionsCommand}"/>
                        <Button Content="☐ Deselect All"     Style="{StaticResource TechButton}" FontSize="10" Padding="8,3" Margin="2,0"
                                Command="{Binding DeselectAllSuggestionsCommand}"/>
                        <TextBlock Text="  Only ✅ Safe items can be deleted from here"
                                   Foreground="#555" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" Margin="12,0"/>
                    </StackPanel>

                    <!-- Suggestions list with checkboxes -->
                    <DataGrid Grid.Row="1" x:Name="dgSuggestions"
                              ItemsSource="{Binding SuggestionItems}"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              Background="#050505" Foreground="#ccc"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#111"
                              BorderThickness="0" RowBackground="#050505" AlternatingRowBackground="#080808"
                              FontFamily="Consolas" FontSize="11" SelectionMode="Single"
                              CanUserSortColumns="True" HeadersVisibility="Column">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#050505"/>
                                <Setter Property="Foreground" Value="#cccccc"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Safe}" Value="True">
                                        <Setter Property="Foreground" Value="#4ade80"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Safe}" Value="False">
                                        <Setter Property="Foreground" Value="#fbbf24"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                        <Setter Property="Background" Value="#0a1a0a"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CanDelete}" Value="False">
                                        <Setter Property="Foreground" Value="#333"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="✓"
                                Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                                Width="36"/>
                            <DataGridTextColumn Header="  Item"     Binding="{Binding Label}"   Width="260" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size"       Binding="{Binding SizeStr}" Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Safe?"      Binding="{Binding SafeStr}" Width="80"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Category"   Binding="{Binding Category}" Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Action"     Binding="{Binding Note}"    Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Delete bar -->
                    <Border Grid.Row="2" Background="#050508" BorderBrush="#00FFFF" BorderThickness="0,1,0,0" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🗑  DELETE SELECTED (SAFE ONLY)"
                                    Style="{StaticResource TechButton}"
                                    FontSize="12" Padding="14,6"
                                    Background="#1a0000" BorderBrush="#ff5f6d" Foreground="#ff5f6d"
                                    Command="{Binding DeleteSuggestionsCommand}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SuggSelectedStr}"
                                       Foreground="#fbbf24" FontFamily="Consolas" FontSize="11"
                                       VerticalAlignment="Center" Margin="16,0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ── Bottom scan bar ────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#050505" BorderBrush="#00FFFF"
                BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="▶  DEEP SCAN" Style="{StaticResource TechButton}"
                        Command="{Binding ScanCommand}" FontSize="13" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="■  CANCEL" Style="{StaticResource TechButton}"
                        Command="{Binding CancelScanCommand}" FontSize="13" Padding="12,6" Margin="0,0,16,0"/>
                <TextBlock Text="{Binding Status}" Foreground="#00FFFF"
                           FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="600"/>
            </StackPanel>
        </Border>
    </Grid>
</TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <!-- Resize Grips -->
        <Grid x:Name="resizeGrid" Visibility="Visible">
            <Rectangle Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
            <Rectangle Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
            <Rectangle Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
            <Rectangle Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
            <Rectangle Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
            <Rectangle Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
            <Rectangle Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Top" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
            <Rectangle Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="ResizeWindow"/>
        </Grid>
    </Grid>
</Window>
